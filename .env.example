# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
# https://supabase.com/dashboard/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only: bypasses Row Level Security for admin operations.
# ⚠️  NEVER expose this to the browser — keep it SERVER-SIDE only (no NEXT_PUBLIC_).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── App ──────────────────────────────────────────────────────────────────────
# Full public URL of your deployed app (no trailing slash)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Slug used to identify the restaurant in multi-tenant setups
NEXT_PUBLIC_RESTAURANT_SLUG=my-restaurant

# ─── Auth (optional but recommended for production) ───────────────────────────
# Generate a long random secret: openssl rand -base64 32
# Used internally by @supabase/ssr to sign session cookies
# NEXTAUTH_SECRET=your-random-secret

# ─── Error Tracking (optional) ────────────────────────────────────────────────
# Add your Sentry DSN after running: npx @sentry/wizard@latest -i nextjs
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_ORG=your-org
# SENTRY_PROJECT=your-project
# SENTRY_AUTH_TOKEN=your-token

# ─── Storage ──────────────────────────────────────────────────────────────────
# Supabase Storage bucket name for menu images (created in DEPLOYMENT.md step 4)
NEXT_PUBLIC_STORAGE_BUCKET=menu-images

# ─── Feature flags (optional) ─────────────────────────────────────────────────
# Set to "true" to force demo mode even when Supabase keys are present
# NEXT_PUBLIC_FORCE_DEMO=false

# ─── DO NOT COMMIT .env.local ─────────────────────────────────────────────────
# This file (.env.example) is safe to commit.
# The real .env.local with actual values must stay in .gitignore.
